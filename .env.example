# ================================
# Solar Panel Cleaner — Environment Variables
# ================================
# PETUNJUK: Salin file ini menjadi '.env' dan isi nilai yang sesuai.
# JANGAN PERNAH commit file '.env' ke Git!
# ================================

# --- Database (PostgreSQL) ---
DB_HOST=postgres
DB_NAME=solar_cleaner_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_PORT=5432

# --- MQTT Broker (Mosquitto) ---
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# --- Flask ---
FLASK_APP=backend.py
FLASK_ENV=production

# --- Timezone ---
TZ=Asia/Jakarta
